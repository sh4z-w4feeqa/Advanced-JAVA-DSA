import java.util.*;
class Post{
  int stack[] = new int[20];
  int top = -1;
  void push(int num){
    stack[++top] = num;
  }
  int pop(){
    return stack[top--];
  }
  void evaluate(String postfix){
    for(int i = 0; i<postfix.length(); i++){
      char ch = postfix.charAt(i);
      if(Character.isDigit(ch)){
        push(ch - '0');
      } else{
        int b = pop(), a = pop();
        if(ch == '+') push(a+b);
        else if(ch == '-') push(a-b);
        else if(ch == '*') push(a*b);
        else if(ch == '/') {
          if(b==0) {
            System.out.print("Error");
            return;
          }
          push(a/b);
        }
      }
    }
    System.out.print(stack[top]);
  }
}
public class Main {
    public static void main(String[] args) {
      Scanner scn = new Scanner(System.in);
      String postfix = scn.next();
      Post p = new Post();
      p.evaluate(postfix);
    }
}
