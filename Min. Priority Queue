import java.util.*;
class Queue{
  int size,n;
  int[] arr;
  Queue(int size){
    this.size=size;
    this.n=0;
    this.arr=new int[size];
  }
  void enqueue(int num){
    if(n==size)
      System.out.print("Queue overflow");
    else 
      arr[n++]=num;
  }
  void dequeue(){
    if(n==0) System.out.print("Queue underflow");
    else {
      int min=0;
      for(int i=0;i<n;i++){
        if(arr[i]<arr[min])
          min=i;
      }
      System.out.println(arr[min]);
      for(int i=min;i<size-1;i++)
        arr[i]=arr[i+1];
      n--;
    }
  }
  void display(){
    if(n==0) 
       System.out.println("Queue is empty");
    for(int i=0;i<n;i++)
      System.out.print(arr[i]+" ");
    System.out.println();
  }
}
public class Main {
    public static void main(String[] args) {
      Scanner sc=new Scanner(System.in);
      int size=sc.nextInt();
      Queue q=new Queue(size);
      while(true){
      int op=sc.nextInt();
      switch(op){
        case 1:
          int num=sc.nextInt();
          q.enqueue(num);
          break;
        case 2:
          q.dequeue();
          break;
        case 3:
          q.display();
          break;
        case 4:
          return;
}}}}
