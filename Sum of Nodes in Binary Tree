import java.util.*;
class Node {
    int data;
    Node left, right;
    Node(int data) {
        this.data = data;
        this.left = null;
        this.right = null;
}}
public class Main {
    static Node buildTree(Scanner scn) {
        int val = scn.nextInt();
        if (val == -1) return null; 
        Node root = new Node(val);
        root.left = buildTree(scn);   
        root.right = buildTree(scn);  
        return root;
    }
    static int sumOfNodes(Node node) {
        if (node == null) return 0;
        int sum = node.data + sumOfNodes(node.left) + sumOfNodes(node.right);
        return sum;
    }
    public static void main(String[] args) {
        Scanner scn = new Scanner(System.in);
        Node root = buildTree(scn);
        System.out.println("Total sum of nodes: " + sumOfNodes(root));
}}
